generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A canonical product groups per-store listings of the "same" app
// (e.g. Spotify on Google Play + Spotify on the App Store).
model Product {
  id        String   @id @default(cuid())
  slug      String   @unique // normalized name, used to match across stores
  name      String
  developer String?
  icon      String?
  category  String? // canonical category key (see src/lib/categories.ts)
  rank      Int? // best rank across stores within the category
  createdAt DateTime @default(now())

  // Cached LLM idea-card summary (JSON: verdict/whyClone/loved/painPoints/
  // howToWin). summaryHash gates regeneration so we only call the model when
  // the underlying review signal actually changed.
  summary     String?
  summaryHash String?

  listings App[]

  @@index([category, rank])
}

// A single per-store listing of a product.
model App {
  id            String    @id @default(cuid())
  store         String // "google" | "apple"
  storeAppId    String // package name (google) or numeric id (apple)
  country       String    @default("us")
  title         String
  icon          String?
  category      String? // canonical category key for this listing
  rank          Int? // position in the store's category top-list
  createdAt     DateTime  @default(now())
  lastScrapedAt DateTime?

  // Popularity / quality / cloneability signals captured at ingest. Some are
  // store-specific (installs/histogram/IAP: google only; size: apple only).
  score          Float? // average star rating
  ratingCount    Int? // number of ratings (google `ratings`, apple `reviews`)
  installs       BigInt? // google minInstalls (can exceed 2^31, e.g. 5B); apple has none
  histogram      String? // JSON {1..5: count}, google only
  free           Boolean?
  offersIAP      Boolean? // google only
  sizeBytes      BigInt? // apple only (apps >2GB exceed 2^31)
  description    String? // store description, used for cloneability heuristics
  screenshots    String? // JSON array of store screenshot URLs
  storeUpdatedAt DateTime?
  releasedAt     DateTime?

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  reviews   Review[]
  positives PositiveReview[]

  @@unique([store, storeAppId, country])
  @@index([productId])
}

model Review {
  id         String    @id @default(cuid())
  app        App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  appId      String
  externalId String
  author     String?
  rating     Int
  title      String?
  text       String
  version    String?
  themes     String    @default("[]") // JSON array of theme keys
  // Semantic needs-classification (offline, Claude-authored). JSON array of
  // labels: [{ key, stance, confidence, trigger }] against src/lib/taxonomy.ts.
  // An empty array means "classified, nothing fit" (honest abstention); null
  // means "not yet classified". needsVersion stamps the taxonomy+prompt version
  // so a re-run only touches rows from an older version (idempotent, gated).
  needs        String?
  needsVersion String?
  // Russian translation of a non-Russian review's title/text, produced by the
  // same keyless dump -> Claude -> apply loop as the classification (see
  // dump-translate.ts). Shown on the RU UI in the evidence popup with a
  // "translated from English" badge; null means not translated (the review is
  // already Russian, or hasn't been run yet). translationVersion stamps the run
  // so re-runs only touch rows from an older version (idempotent, gated).
  titleRu            String?
  textRu             String?
  translationVersion String?
  postedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([appId, externalId])
  @@index([appId, rating])
}

// A sample of 4-5 star reviews, kept to surface what users LOVE about an app
// (the "why it works" side of an idea card). Separate from Review so all the
// negative-complaint queries stay untouched.
model PositiveReview {
  id         String    @id @default(cuid())
  app        App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  appId      String
  externalId String
  author     String?
  rating     Int
  title      String?
  text       String
  loved      String    @default("[]") // JSON array of loved-theme keys
  postedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@unique([appId, externalId])
  @@index([appId])
}

// ── Auth / premium (Telegram login + Stars subscription) ──────────────────
model User {
  id           String    @id @default(cuid())
  telegramId   String?   @unique
  googleId     String?   @unique
  email        String?   @unique
  username     String?
  firstName    String?
  premiumUntil DateTime?
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
}

// Short-lived web login handshake: web creates a token, user opens the bot via
// t.me/<bot>?start=login_<token>, bot stamps telegramId, web polls + sets session.
model LoginToken {
  token      String   @id
  telegramId String?
  username   String?
  firstName  String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}
